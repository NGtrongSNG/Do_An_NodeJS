<%- include ('../partitals/user/head')%>
    <%- include ('../partitals/user/header')%>
        <%- include ('../partitals/user/navbar')%>
<div class="container-fluid mt-3">
    <div class="container">
        <nav class="breadcrumb bg-light p-2 shadow-sm" style="border-radius: 5px;">
            <a class="breadcrumb-item text-dark" href="/"><i class="fas fa-home"></i> Trang chủ</a>
            <a class="breadcrumb-item text-dark" href="/category/<%= post.category_id %>"><%= post.category_name %></a>
            <span class="breadcrumb-item active text-primary font-weight-bold"><%= post.Title %></span>
        </nav>
    </div>
</div>

<div class="container-fluid py-3">
    <div class="container">
        <div class="row">
            <div class="col-lg-8">
                <div class="bg-white p-4 shadow-sm border" style="border-radius: 8px;">
                    <div class="mb-3 d-flex align-items-center justify-content-between">
                        <a href="/category/<%= post.category_id %>" class="badge badge-primary text-uppercase font-weight-semi-bold p-2">
                            <%= post.category_name %>
                        </a>
                        <div class="text-muted small">
                            <span class="mr-3"><i class="far fa-calendar-alt mr-1"></i><%= post.Create_at.toLocaleDateString() %></span>
                            <span class="mr-3"><i class="far fa-eye mr-1"></i><%= post.views %> lượt xem</span>
                        </div>
                    </div>

                    <h1 class="mb-3 text-dark font-weight-bold" style="font-size: 2.2rem; line-height: 1.2;">
                        <%= post.Title %>
                    </h1>

                    <div class="d-flex align-items-center mb-4 p-2 bg-light border-left border-primary">
                        <i class="fas fa-user-edit text-primary mr-2"></i>
                        <span class="font-weight-bold text-dark mr-1">Biên tập:</span>
                        <span class="text-primary font-italic"><%= post.fullname %></span>
                    </div>

                    <div class="mb-4 text-center">
                        <img class="img-fluid w-100 shadow-sm" src="/img/<%= post.Image %>" 
                             style="max-height: 450px; object-fit: cover; border-radius: 5px;" alt="<%= post.Title %>">
                    </div>

                    <div class="p-3 mb-4 bg-light font-weight-bold text-dark border-left border-warning" 
                         style="font-size: 1.1rem; line-height: 1.6; border-width: 5px !important;">
                        <%= post.Summary %>
                    </div>

                    <div class="post-content text-dark" style="font-size: 1.1rem; line-height: 1.8;">
                        <%- post.Content %>
                    </div>

                    <hr class="mt-5">
                    <div class="d-flex align-items-center">
                        <span class="mr-3 font-weight-bold">Chia sẻ:</span>
                        <a href="#" class="btn btn-sm btn-outline-primary mr-2"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" class="btn btn-sm btn-outline-info mr-2"><i class="fab fa-twitter"></i></a>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="mb-4">
                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold bg-dark text-white p-2 text-center" style="border-radius: 5px 5px 0 0;">Danh mục</h4>
                    </div>
                    <div class="bg-white border border-top-0 p-3 shadow-sm">
                        <% categories.forEach(cat => { %>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <a href="/category/<%= cat.ID %>" class="text-secondary font-weight-medium text-decoration-none">
                                    <i class="fas fa-angle-right mr-2 text-primary"></i><%= cat.name %>
                                </a>
                                <span class="badge badge-primary badge-pill"><%= cat.post_count %></span>
                            </div>
                        <% }) %>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="section-title mb-0">
                        <h4 class="m-0 text-uppercase font-weight-bold bg-dark text-white p-2 text-center" style="border-radius: 5px 5px 0 0;">Bài liên quan</h4>
                    </div>
                    <div class="bg-white border border-top-0 p-3 shadow-sm">
                        <% related.forEach(rel => { %>
                            <div class="d-flex align-items-center mb-3">
                                <img class="img-fluid rounded" src="/img/<%= rel.Image %>" style="width: 80px; height: 80px; object-fit: cover;" alt="">
                                <div class="pl-3">
                                    <a class="h6 m-0 text-secondary text-uppercase font-weight-bold" href="/posts/<%= rel.ID %>" style="font-size: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                                        <%= rel.Title %>
                                    </a>
                                    <small class="text-muted"><%= rel.Create_at.toLocaleDateString() %></small>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

            <%- include ('../partitals/user/footer')%>