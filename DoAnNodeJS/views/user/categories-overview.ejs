<%- include ('../partitals/user/head')%>
<%- include ('../partitals/user/header')%>
<%- include ('../partitals/user/navbar')%>
<div class="container py-5">
    <div class="section-title mb-5 text-center">
        <h1 class="display-4 font-weight-bold text-uppercase">Khám Phá Tin Tức</h1>
        <p class="text-muted">Tổng hợp các bài viết mới nhất theo từng chuyên mục</p>
    </div>

    <% categoriesWithPosts.forEach(section => { %>
        <div class="mb-5">
            <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-4">
                <h3 class="font-weight-bold text-uppercase m-0">
                    <span class="text-primary">#</span> <%= section.categoryName %>
                </h3>
                <a href="/category/<%= section.categoryId %>" class="btn btn-sm btn-outline-primary">
                    Xem tất cả <i class="fas fa-angle-double-right"></i>
                </a>
            </div>

            <div class="row">
                <% if (section.posts.length > 0) { %>
                    <% section.posts.forEach(post => { %>
                        <div class="col-lg-3 col-md-6 mb-4">
                            <div class="card h-100 border-0 shadow-sm overflow-hidden" style="transition: 0.3s;">
                                <div class="position-relative">
                                    <img src="/img/<%= post.Image %>" class="card-img-top" style="height: 180px; object-fit: cover;" alt="">
                                    <div class="position-absolute bg-dark text-white p-1 px-2" style="bottom: 0; left: 0; font-size: 11px; opacity: 0.8;">
                                        <i class="far fa-clock"></i> <%= post.Create_at.toLocaleDateString() %>
                                    </div>
                                </div>

                                <div class="card-body p-3">
                                    <h6 class="card-title font-weight-bold" style="line-height: 1.4; height: 40px; overflow: hidden;">
                                        <a href="/posts/<%= post.id || post.ID %>" class="text-dark text-decoration-none">
                                            <%= post.Title %>
                                        </a>
                                    </h6>
                                    <p class="card-text text-muted small" style="height: 60px; overflow: hidden;">
                                        <%= post.Summary ? post.Summary.substring(0, 80) : 'Đang cập nhật nội dung...' %>...
                                    </p>
                                </div>

                                <div class="card-footer bg-transparent border-0 pt-0 pb-3">
                                    <hr class="mt-0">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <small class="text-secondary"><i class="fas fa-user-edit mr-1"></i><%= post.fullname %></small>
                                        <small class="text-muted"><i class="far fa-eye"></i> <%= post.views %></small>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                <% } else { %>
                    <div class="col-12">
                        <p class="text-italic text-muted ml-3">Chưa có bài viết nào trong mục này.</p>
                    </div>
                <% } %>
            </div>
        </div>
    <% }) %>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
</style>

<%- include ('../partitals/user/footer')%>